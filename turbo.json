{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": ["NEXTAUTH_SECRET", "NODE_ENV", "SECRETTUNNEL_API_URL", "API_URL", "QSTASH_TOKEN", "QSTASH_CURRENT_SIGNING_KEY", "QSTASH_NEXT_SIGNING_KEY"],
  "globalPassThroughEnv": ["NEXTAUTH_SECRET", "NODE_ENV", "SECRETTUNNEL_API_URL", "API_URL", "QSTASH_TOKEN", "QSTASH_CURRENT_SIGNING_KEY", "QSTASH_NEXT_SIGNING_KEY"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": ["NEXTAUTH_SECRET"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "env": ["NEXTAUTH_SECRET"]
    },
    "check-types": {
      "dependsOn": ["^check-types"],
      "env": ["NEXTAUTH_SECRET"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["NEXTAUTH_SECRET"]
    }
  }
}
